# Global Sync Service - Environment Variables
# Copy to .env and fill in actual values

# Application
APP_VERSION=0.1.0
APP_ENV=development
REGION=na
LOG_LEVEL=debug
LOG_FORMAT=console

# HTTP
HTTP_PORT=8080

# PostgreSQL - Regional DB
REGIONAL_DB_HOST=localhost
REGIONAL_DB_PORT=5432
REGIONAL_DB_USER=postgres
REGIONAL_DB_PASSWORD=
REGIONAL_DB_NAME=wigowago_regional
REGIONAL_DB_SSL_MODE=disable

# PostgreSQL - Global Index DB
GLOBAL_INDEX_DB_HOST=localhost
GLOBAL_INDEX_DB_PORT=5433
GLOBAL_INDEX_DB_USER=postgres
GLOBAL_INDEX_DB_PASSWORD=
GLOBAL_INDEX_DB_NAME=wigowago_global_index
GLOBAL_INDEX_DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RocketMQ
ROCKETMQ_NAME_SERVER=localhost:9876
ROCKETMQ_GROUP_ID=global-sync-group
ROCKETMQ_TOPIC=sync-events
ROCKETMQ_CONSUMER=sync-consumer

# Cross-region sync
CROSS_SYNC_PEER_URL=http://peer-sync-service:8080
CROSS_SYNC_TIMEOUT=10s

# Feed generation
FEED_PUSH_THRESHOLD=1000
