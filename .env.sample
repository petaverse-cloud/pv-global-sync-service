# Global Sync Service - Environment Variables
# Shared infrastructure: Azure RDS PostgreSQL + Redis Stack + RocketMQ

# Application
APP_VERSION=0.1.0
APP_ENV=development
REGION=na
LOG_LEVEL=debug
LOG_FORMAT=console

# HTTP
HTTP_PORT=8080

# PostgreSQL - Shared Azure RDS (same as pawly-agent)
# Both Regional DB and Global Index DB use the same RDS instance
# CREATE DATABASE wigowago_regional;
# CREATE DATABASE wigowago_global_index;
REGIONAL_DB_HOST=rds-postgres-dev.postgres.database.azure.com
REGIONAL_DB_PORT=5432
REGIONAL_DB_USER=postgres
REGIONAL_DB_PASSWORD=
REGIONAL_DB_NAME=wigowago_regional
REGIONAL_DB_SSL_MODE=require

GLOBAL_INDEX_DB_HOST=rds-postgres-dev.postgres.database.azure.com
GLOBAL_INDEX_DB_PORT=5432
GLOBAL_INDEX_DB_USER=postgres
GLOBAL_INDEX_DB_PASSWORD=
GLOBAL_INDEX_DB_NAME=wigowago_global_index
GLOBAL_INDEX_DB_SSL_MODE=require

# Redis Stack (shared, using DB2)
# redis-dev.verse4.pet:6379
REDIS_HOST=redis-dev.verse4.pet
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=2

# RocketMQ (devops cluster)
ROCKETMQ_NAME_SERVER=localhost:9876
ROCKETMQ_GROUP_ID=global-sync-group
ROCKETMQ_TOPIC=sync-events
ROCKETMQ_CONSUMER=sync-consumer

# Cross-region sync (empty for single-region dev)
CROSS_SYNC_PEER_URL=
CROSS_SYNC_TIMEOUT=10s

# Feed generation
FEED_PUSH_THRESHOLD=1000
